{
  "name": "apps-script-sample",
  "private": true,
  "version": "0.2.8",
  "description": "Sample Apps Script Web App for use with Empower Poster extension",
  "author": "Ted Romer <tromer@gmail.com>",
  "license": "MIT",
  "keywords": [
    "finance"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && rollup --config --no-treeshake && cp appsscript.json dist/",
    "build:check": "yarn check && yarn build",
    "build:redeploy": "yarn build:check && yarn redeploy",
    "redeploy": "./clasp-redeploy.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint './*.{js,ts}' '{src,tests}/**/*.{js,ts}'",
    "lint:fix": "yarn lint --fix",
    "format:check": "prettier './*.{js,ts}' '{src,tests}/**/*.{js,ts}' --check",
    "format": "prettier './*.{js,ts}' '{src,tests}/**/*.{js,ts}' --write",
    "check": "yarn typecheck && yarn lint && yarn format:check",
    "fix": "yarn lint:fix && yarn format",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "yarn check && yarn test"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "^2.0.8",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "rollup": "^4.61.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.8"
  }
}
