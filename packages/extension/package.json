{
  "name": "extension",
  "private": true,
  "description": "Browser extension that posts Empower data to a user-provided endpoint",
  "version": "0.2.5",
  "author": "Ted Romer <tromer@gmail.com>",
  "license": "MIT",
  "keywords": [
    "finance"
  ],
  "homepage": "https://github.com/righteffort/empower-poster#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/righteffort/empower-poster.git",
    "directory": "node/fidelity-helper"
  },
  "bugs": {
    "url": "https://github.com/righteffort/empower-poster/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "vite build",
    "build:check": "yarn check && yarn build",
    "dist": "rm -f dist.zip && yarn build && cd dist && zip -r ../dist.zip *",
    "cli": "tsc -p tsconfig-cli.json && node dist-cli/cli/cli.js",
    "clean": "rm -rf dist dist-cli",
    "typecheck": "tsc --noEmit",
    "lint": "eslint '{src,tests}/**/*.{js,ts}'",
    "lint:fix": "yarn lint --fix",
    "format:check": "prettier '{src,tests}/**/*.{js,ts}' --check",
    "format": "prettier '{src,tests}/**/*.{js,ts}' --write",
    "check": "yarn typecheck && yarn lint && yarn format:check",
    "fix": "yarn lint:fix && yarn format",
    "test:watch": "vitest",
    "test": "vitest run",
    "ci": "yarn check && yarn test"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^25.0.3",
    "@types/webextension-polyfill": "^0.10.0",
    "eslint": "^9.35.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.16",
    "webextension-polyfill": "^0.10.0"
  }
}
